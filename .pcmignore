# ProjectCodeMap Ignore Rules
# This file works like .gitignore but for ProjectCodeMap scanning
# Place this in your project root to exclude files/directories from the map

# Dependencies
node_modules/
vendor/
.env
.venv
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# Build outputs
dist/
build/
*.egg-info/
target/
out/
bin/
obj/

# IDE / Editor
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Logs & Temp
*.log
*.tmp
*.temp
tmp/
temp/

# CI/CD
.github/
.gitlab/
.circleci/

# Documentation (optional - uncomment to exclude)
# docs/
# *.md
# *.rst

# Test outputs
test-results/
coverage/
*.lcov

# OS generated
Thumbs.db
ehthumbs.db
Desktop.ini